# ============================================
# ScholarMind Environment Variables
# ============================================

# === LLM Providers ===
GROQ_API_KEY=gsk_your_groq_api_key_here
HF_TOKEN=hf_your_huggingface_token_here

# === Optional LLM Fallback ===
OPENAI_API_KEY=

# === Database ===
# Local development (SQLite):
SQLITE_URL=sqlite+aiosqlite:///./data/scholarmind.db
# Production (Neon PostgreSQL — set this to use PostgreSQL instead of SQLite):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/scholarmind?sslmode=require

# === Redis Cache (Cloud) ===
# Production (Upstash Redis):
# REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# === Vector Store ===
CHROMA_PERSIST_DIR=./data/chroma

# === MLflow ===
MLFLOW_TRACKING_URI=./data/mlflow

# === Ingestion ===
SCRAPE_INTERVAL_HOURS=6
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.CV,stat.ML
PUBMED_QUERY=machine learning healthcare

# === LLMOps ===
CACHE_SIMILARITY_THRESHOLD=0.95
LLM_COST_ALERT_PER_HOUR=5.0
DEFAULT_SYNTHESIS_MODEL=mixtral-8x7b-32768

# === Frontend ===
# Local:
NEXT_PUBLIC_API_URL=http://localhost:7860
# Production (your HuggingFace Spaces URL):
# NEXT_PUBLIC_API_URL=https://your-username-scholarmind.hf.space

# === CORS (add your Vercel domain) ===
# CORS_ORIGINS=http://localhost:3000,https://scholarmind.vercel.app,https://your-username-scholarmind.hf.space
